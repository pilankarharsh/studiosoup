        </div>
        <div class="swiper-slide relative">
          <img
            src={projectglimpses2.url}
            alt="Interior design project showcase - Contemporary kitchen design"
          />
        </div>
        <div class="swiper-slide relative">
          <img
            src={projectglimpses3.url}
            alt="Interior design project showcase - Luxury bedroom design"
          />
        </div>
        <div class="swiper-slide relative">
          <img
            src={projectglimpses4.url}
            alt="Interior design project showcase - Commercial space design"
          />
        </div>
        <div class="swiper-slide relative">
          <img
            src={projectglimpses5.url}
            alt="Interior design project showcase - Modern living room"
          />
        </div>
        <div class="swiper-slide relative">
          <img
            src={projectglimpses6.url}
